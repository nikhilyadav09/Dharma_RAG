# Database Configuration
DB_NAME=ancient_wisdoms
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_HOST=localhost

# LLM Configuration
LLM_API_KEY_1=your_groq_api_key_1
LLM_API_KEY_2=your_groq_api_key_2
