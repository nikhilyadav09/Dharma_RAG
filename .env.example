# =============================================================================
# DHARMA — Environment Variables Reference
# =============================================================================
# Copy to .env for local development. Set in Render / Vercel / Neon dashboards
# for production. NEVER commit real secrets to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (local Docker defaults below; Neon uses DB_SSLMODE=require)
# -----------------------------------------------------------------------------
DB_NAME=ancient_wisdoms
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
# Required for Neon and most managed Postgres providers:
# DB_SSLMODE=require

# -----------------------------------------------------------------------------
# LLM — Groq (https://console.groq.com)
# -----------------------------------------------------------------------------
LLM_API_KEY_1=your_groq_api_key_1
LLM_API_KEY_2=
LLM_API_KEY_3=
LLM_MODEL_NAME=llama-3.3-70b-versatile
LLM_MAX_TOKENS=900
LLM_TEMPERATURE=0.5

# -----------------------------------------------------------------------------
# RAG / Retrieval
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
SEMANTIC_WEIGHT=0.65
BM25_WEIGHT=0.35
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATES=12
CONTEXT_VERSES=3
SEMANTIC_THRESHOLD=0.25
ENABLE_RERANKER=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
RERANK_TOP_N=5
SCRIPTURE_BOOST=0.12
MAX_PASSAGE_CHARS=1200

# Render free tier: set ENABLE_RERANKER=false if the service runs out of memory

# -----------------------------------------------------------------------------
# Cache (optional — not wired in pipeline yet)
# -----------------------------------------------------------------------------
CACHE_ENABLED=True
CACHE_EXPIRY=3600

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# Local development:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production example (Render):
# CORS_ORIGINS=https://dharma.nikhilyadav.dev

# -----------------------------------------------------------------------------
# Frontend (Vercel) — set in Vercel project Environment Variables
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL=https://api.dharma.nikhilyadav.dev
