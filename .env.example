# Database Configuration
# Defaults below match docker-compose.yml (recommended setup)
DB_NAME=ancient_wisdoms
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# LLM Configuration (at least LLM_API_KEY_1 is required to get real answers)
# Get a free key at https://console.groq.com
LLM_API_KEY_1=your_groq_api_key_1
LLM_API_KEY_2=
LLM_API_KEY_3=
LLM_MODEL_NAME=llama-3.3-70b-versatile
LLM_MAX_TOKENS=900
LLM_TEMPERATURE=0.5

# RAG / Retrieval Configuration
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
SEMANTIC_WEIGHT=0.65
BM25_WEIGHT=0.35
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATES=12
CONTEXT_VERSES=3
SEMANTIC_THRESHOLD=0.25
ENABLE_RERANKER=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
RERANK_TOP_N=5
SCRIPTURE_BOOST=0.12
MAX_PASSAGE_CHARS=1200

# Cache Configuration
CACHE_ENABLED=True
CACHE_EXPIRY=3600

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
